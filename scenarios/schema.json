{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/RonanDavalan/diwall/main/scenarios/schema.json",
  "title": "Diwall scenario",
  "description": "Formal contract for a Diwall scenario: a root object with a target URL and a list of typed actions executed sequentially by shot.py and rpa.py.",
  "type": "object",
  "required": ["url", "actions"],
  "additionalProperties": false,
  "properties": {
    "$schema":     { "type": "string" },
    "nom":         { "type": "string" },
    "description": { "type": "string" },
    "intention":      { "type": "string" },
    "auth_indicator": { "type": "string", "minLength": 1,
                        "description": "CSS selector visible only when authenticated — adds auth_status to shot.py JSON output (v1.9)" },
    "url":         { "type": "string", "format": "uri" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Action" }
    }
  },
  "definitions": {
    "Action": {
      "oneOf": [
        { "$ref": "#/definitions/Naviguer" },
        { "$ref": "#/definitions/Cliquer" },
        { "$ref": "#/definitions/CliquerSom" },
        { "$ref": "#/definitions/CliquerVisuel" },
        { "$ref": "#/definitions/Remplir" },
        { "$ref": "#/definitions/RemplirSom" },
        { "$ref": "#/definitions/Attendre" },
        { "$ref": "#/definitions/AttendreNavigation" },
        { "$ref": "#/definitions/Pause" },
        { "$ref": "#/definitions/Capturer" },
        { "$ref": "#/definitions/Evaluer" },
        { "$ref": "#/definitions/Defiler" },
        { "$ref": "#/definitions/AttendreNtfy" },
        { "$ref": "#/definitions/AttendreUrl" },
        { "$ref": "#/definitions/AttendreSelecteurPresent" },
        { "$ref": "#/definitions/AttendreAbsence" },
        { "$ref": "#/definitions/AttendreReseauCalme" },
        { "$ref": "#/definitions/NettoyerOverlay" },
        { "$ref": "#/definitions/DeclencherScenario" }
      ]
    },

    "Naviguer": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "naviguer" },
        "url":  { "type": "string", "format": "uri" }
      }
    },

    "Cliquer": {
      "type": "object",
      "required": ["type", "selecteur"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "cliquer" },
        "selecteur": { "type": "string", "minLength": 1 }
      }
    },

    "CliquerSom": {
      "type": "object",
      "required": ["type", "id"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "cliquer_som" },
        "id":   { "type": "integer", "minimum": 1 }
      }
    },

    "CliquerVisuel": {
      "type": "object",
      "required": ["type", "description"],
      "additionalProperties": false,
      "properties": {
        "type":        { "const": "cliquer_visuel" },
        "description": { "type": "string", "minLength": 1 }
      }
    },

    "Remplir": {
      "type": "object",
      "required": ["type", "selecteur", "valeur"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "remplir" },
        "selecteur": { "type": "string", "minLength": 1 },
        "valeur":    { "type": "string" },
        "vault_cle": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "valeur": { "const": "depuis_vault" } },
            "required": ["valeur"]
          },
          "then": { "required": ["vault_cle"] }
        }
      ]
    },

    "RemplirSom": {
      "type": "object",
      "required": ["type", "id", "valeur"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "remplir_som" },
        "id":        { "type": "integer", "minimum": 1 },
        "valeur":    { "type": "string" },
        "vault_cle": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "valeur": { "const": "depuis_vault" } },
            "required": ["valeur"]
          },
          "then": { "required": ["vault_cle"] }
        }
      ]
    },

    "Attendre": {
      "type": "object",
      "required": ["type", "selecteur"],
      "additionalProperties": false,
      "properties": {
        "type":             { "const": "attendre" },
        "selecteur":        { "type": "string", "minLength": 1 },
        "interval_capture": { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "AttendreNavigation": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type":             { "const": "attendre_navigation" },
        "interval_capture": { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "Pause": {
      "type": "object",
      "required": ["type", "ms"],
      "additionalProperties": false,
      "properties": {
        "type":             { "const": "pause" },
        "ms":               { "type": "integer", "minimum": 0 },
        "interval_capture": { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "Capturer": {
      "type": "object",
      "required": ["type", "nom"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "capturer" },
        "nom":  { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "som":  { "type": "boolean" }
      }
    },

    "Evaluer": {
      "type": "object",
      "required": ["type", "script"],
      "additionalProperties": false,
      "properties": {
        "type":    { "const": "evaluer" },
        "script":  { "type": "string", "minLength": 1 },
        "attendu": {}
      }
    },

    "Defiler": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "defiler" },
        "px":        { "type": "integer" },
        "selecteur": { "type": "string", "minLength": 1 }
      },
      "oneOf": [
        { "required": ["px"] },
        { "required": ["selecteur"] }
      ]
    },

    "AttendreNtfy": {
      "type": "object",
      "required": ["type", "id_som"],
      "additionalProperties": false,
      "properties": {
        "type":    { "const": "attendre_mfa_ntfy" },
        "id_som":  { "type": "integer", "minimum": 1 },
        "timeout": { "type": "integer", "minimum": 10, "default": 120 }
      }
    },

    "AttendreUrl": {
      "type": "object",
      "required": ["type", "motif"],
      "additionalProperties": false,
      "properties": {
        "type":  { "const": "attendre_url" },
        "motif": { "type": "string", "minLength": 1,
                   "description": "Sub-string to match in the current URL (wrapped in ** glob pattern)" }
      }
    },

    "AttendreSelecteurPresent": {
      "type": "object",
      "required": ["type", "selecteur"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "attendre_selecteur_present" },
        "selecteur": { "type": "string", "minLength": 1,
                       "description": "CSS selector — waits until element is visible (state=visible)" }
      }
    },

    "AttendreAbsence": {
      "type": "object",
      "required": ["type", "selecteur"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "attendre_absence" },
        "selecteur": { "type": "string", "minLength": 1,
                       "description": "CSS selector — waits until element is removed from DOM (state=detached)" },
        "delai_initial_ms": { "type": "integer", "minimum": 0,
                              "description": "Optional delay (ms) before polling starts — use on first POST submission to let Playwright process the redirect (REX #66)" }
      }
    },

    "AttendreReseauCalme": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type":       { "const": "attendre_reseau_calme" },
        "timeout_ms": { "type": "integer", "minimum": 0,
                        "description": "Max wait in ms before abort (distinct from the 500ms internal silence threshold)" }
      }
    },

    "NettoyerOverlay": {
      "type": "object",
      "required": ["type", "selecteur"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "nettoyer_overlay" },
        "selecteur": { "type": "string", "minLength": 1,
                       "description": "CSS selector of overlays to hide (visibility:hidden). Must be explicit — no auto-detection. Execute before SoM generation." }
      }
    },

    "DeclencherScenario": {
      "type": "object",
      "required": ["type", "scenario"],
      "additionalProperties": false,
      "properties": {
        "type":     { "const": "declencher_scenario" },
        "scenario": { "type": "string", "minLength": 1,
                      "description": "Name or path of the sub-scenario to inline. Resolved via the same cascade as --scenario CLI (scenarios/<name>{.json,.yaml,.yml}). Max depth: 5." }
      }
    }
  }
}
